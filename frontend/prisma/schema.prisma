generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// BetterAuth Models
// ============================================

model User {
  id            String    @id
  name          String?
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions      Session[]
  accounts      Account[]

  tasks          HumanTask[]
  automatedTasks AutomatedTask[]
  skills         UserSkill[]
  connections    UserConnection[]
  chatMessages   ChatMessage[]
  taskChannels   TaskChannel[]

  @@map("users")
}

model Session {
  id        String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("sessions")
}

model Account {
  id                    String    @id
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("accounts")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verifications")
}

// ============================================
// Enums
// ============================================

enum TaskStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum TaskRecurrence {
  ONCE
  DAILY
  WEEKLY
  MONTHLY
  CUSTOM
}

enum TaskEvidenceType {
  PHOTO
  VIDEO
  TEXT
  DOCUMENT
  LOCATION
  AUDIO
  ANY
}

enum SubmissionStatus {
  PENDING
  SUBMITTED
  VETTED
  APPROVED
  REJECTED
  MISSED
  RESUBMITTED
}

enum WorkerStatus {
  ONBOARDING
  ACTIVE
  INACTIVE
  REMOVED
}

enum ChatPlatform {
  WHATSAPP
  TELEGRAM
  SLACK
  DISCORD
  WEB
  WEBHOOK
}

// ============================================
// Task Management
// ============================================

model HumanTask {
  id                  String           @id @default(cuid())
  userId              String
  user                User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                String
  description         String?
  evidenceType        TaskEvidenceType @default(PHOTO)
  recurrenceType      TaskRecurrence   @default(DAILY)
  recurrenceInterval  Int?
  scheduledTimes      Json             @default("[]")
  timezone            String           @default("UTC")
  acceptanceRules     Json             @default("[]")
  sampleEvidenceUrl   String?
  scoringEnabled      Boolean          @default(true)
  passingScore        Int              @default(70)
  graceMinutes        Int              @default(15)
  resubmissionAllowed Boolean          @default(true)
  reportTime          String           @default("18:00")
  reportChannelId     String?
  deliveryConfig      Json?
  reportFolderId      String?
  status              TaskStatus       @default(ACTIVE)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  workers     HumanWorker[]
  submissions TaskSubmission[]
  reports     TaskComplianceReport[]

  taskChannelId String?
  taskChannel   TaskChannel? @relation("TaskNotificationChannel", fields: [taskChannelId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@map("human_tasks")
}

model TaskChannel {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  label     String       @default("Task Channel")
  platform  ChatPlatform
  status    String       @default("pending")

  telegramBotToken   String?
  telegramBotUsername String?

  slackBotToken      String?
  slackSigningSecret String?
  slackTeamId        String?
  slackChannelId     String?

  discordBotToken    String?
  discordGuildId     String?
  discordChannelId   String?

  webhookUrl         String?
  sharedSecret       String?

  tasks   HumanTask[]   @relation("TaskNotificationChannel")
  workers HumanWorker[] @relation("WorkerTaskChannel")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, label])
  @@index([userId])
  @@index([platform])
  @@map("task_channels")
}

model HumanWorker {
  id            String       @id @default(cuid())
  humanTaskId   String
  humanTask     HumanTask    @relation(fields: [humanTaskId], references: [id], onDelete: Cascade)
  name          String
  phone         String?
  platform      ChatPlatform
  externalId    String
  taskChannelId String?
  taskChannel   TaskChannel? @relation("WorkerTaskChannel", fields: [taskChannelId], references: [id], onDelete: SetNull)
  role          String?
  status        WorkerStatus @default(ONBOARDING)
  onboardedAt   DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  submissions TaskSubmission[]

  @@unique([humanTaskId, platform, externalId])
  @@index([humanTaskId])
  @@index([platform, externalId])
  @@map("human_workers")
}

model TaskSubmission {
  id                     String           @id @default(cuid())
  humanTaskId            String
  humanTask              HumanTask        @relation(fields: [humanTaskId], references: [id], onDelete: Cascade)
  workerId               String
  worker                 HumanWorker      @relation(fields: [workerId], references: [id], onDelete: Cascade)
  dueAt                  DateTime
  submittedAt            DateTime?
  latenessSeconds        Int?
  imageUrl               String?
  rawMessage             String?
  aiScore                Int?
  aiFindings             String?
  aiFeedback             String?
  status                 SubmissionStatus @default(PENDING)
  vetAttempts            Int              @default(0)
  reportIncluded         Boolean          @default(false)
  reminderSentAt         DateTime?
  upcomingReminderSentAt DateTime?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  @@index([humanTaskId])
  @@index([workerId])
  @@index([status])
  @@index([dueAt])
  @@index([status, dueAt])
  @@map("task_submissions")
}

model TaskComplianceReport {
  id               String    @id @default(cuid())
  humanTaskId      String
  humanTask        HumanTask @relation(fields: [humanTaskId], references: [id], onDelete: Cascade)
  periodStart      DateTime
  periodEnd        DateTime
  summaryMarkdown  String
  totalSubmissions Int       @default(0)
  missedCount      Int       @default(0)
  avgScore         Float?
  passRate         Float?
  flaggedWorkerIds String[]
  documentUrl      String?
  deliveredAt      DateTime?
  deliveredTo      Json?
  createdAt        DateTime  @default(now())

  @@index([humanTaskId])
  @@index([periodStart])
  @@map("task_compliance_reports")
}

// ============================================
// Skills
// ============================================

model UserSkill {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?
  url         String?
  content     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@map("user_skills")
}

// ============================================
// MCP Connections
// ============================================

model UserConnection {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  type        String
  description String?
  config      Json
  isActive    Boolean  @default(true)
  lastUsedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@map("user_connections")
}

// ============================================
// Automated Tasks
// ============================================

model AutomatedTask {
  id             String            @id @default(cuid())
  userId         String
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  prompt         String
  composioApps   Json              @default("[]")
  scheduledTimes Json              @default("[]")
  timezone       String            @default("UTC")
  deliveryConfig Json?
  status         TaskStatus        @default(ACTIVE)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  runs           AutomatedTaskRun[]

  @@index([userId])
  @@index([status])
  @@map("automated_tasks")
}

model AutomatedTaskRun {
  id              String        @id @default(cuid())
  automatedTaskId String
  automatedTask   AutomatedTask @relation(fields: [automatedTaskId], references: [id], onDelete: Cascade)
  triggeredBy     String
  status          String        @default("RUNNING")
  result          String?
  error           String?
  startedAt       DateTime      @default(now())
  completedAt     DateTime?

  @@index([automatedTaskId])
  @@index([status])
  @@map("automated_task_runs")
}

// ============================================
// Chat Messages (Isaac conversation history)
// ============================================

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId String
  role      String
  content   String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([sessionId])
  @@index([userId, sessionId])
  @@map("chat_messages")
}
