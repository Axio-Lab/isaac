{
  "name": "@isaac/frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "node ./scripts/run-next-with-log-redaction.mjs dev",
    "prisma:generate": "prisma generate --no-engine --schema prisma/schema.prisma",
    "build": "npm run prisma:generate && next build",
    "start": "node ./scripts/run-next-with-log-redaction.mjs start",
    "lint": "next lint",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\" \"*.{ts,tsx}\""
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^6.17.1",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@tanstack/react-query": "^5.75.0",
    "better-auth": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.510.0",
    "next": "^15.3.0",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.56.0",
    "react-markdown": "^10.1.0",
    "resend": "^6.9.4",
    "sonner": "^2.0.0",
    "tailwind-merge": "^3.0.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "postcss": "^8.5.0",
    "prettier": "^3.8.1",
    "prisma": "^6.17.1",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.7.0"
  }
}
